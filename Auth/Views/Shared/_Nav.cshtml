@using Duende.IdentityServer.Extensions
@{
    string name = null;
    if (!true.Equals(ViewData["signed-out"]))
    {
        name = Context.User?.GetDisplayName();
    }
}
<link rel="stylesheet" href="styles.css">

<div class="nav-page">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="#">
                <img src="~/aiimg.png" class="d-inline-block align-top" alt="Logo da Copa Sesc" width="200" height="200">
            </a>
            <h1 class="text-white">Meu sistema Matheus Pessoa.</h1>
            <p class="text-white">Auto geręnciamento. </p>

            @if (!string.IsNullOrWhiteSpace(name))
            {
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item dropdown">
                        <a href="#" class="nav-link dropdown-toggle text-white" role="button" data-bs-toggle="dropdown" aria-expanded="false">@name</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-action="Logout" asp-controller="Account">Logout</a></li>
                        </ul>
                    </li>
                </ul>
            }
        </div>
    </nav>
</div>

<main class="container mt-4">



</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
