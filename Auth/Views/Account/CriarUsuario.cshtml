@model Auth.Models.CriarUsuarioModel

@if (ViewBag.EmailError != null)
{
    <div class="alert alert-danger">@ViewBag.EmailError</div>
}

<!-- ... Seu cabeçalho ... -->
<style>

    body {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh; /* Isso é para centralizar verticalmente */
        margin: 0;
        background-color: #f4f4f4; /* Cor de fundo da página */
    }


    /* ... Seu cabeçalho ... */
    span {
        color: red;
        font-size: 11px;
    }

    .container {
        width: 400px; /* ou qualquer largura desejada */
        background-color: #ffffff; /* Cor de fundo do contêiner */
        border: 1px solid #ddd; /* Borda ao redor do contêiner */
        padding: 20px; /* Espaçamento interno do contêiner */
        border-radius: 8px; /* Borda arredondada do contêiner */
    }

    .d-flex {
        display: flex;
        flex-grow: initial;
    }
</style>

<form asp-action="CriarUsuario">
    <div class="d-flex">
        <div class="form-group col-md-5">
            <label asp-for="FirstName">Nome</label>
            <input asp-for="FirstName" class="form-control" />
            <span class="validation-message" asp-validation-for="FirstName"></span>
        </div>
        <div class="form-group col-md-5">
            <label asp-for="LastName">Sobrenome</label>
            <input asp-for="LastName" class="form-control" />
            <span class="validation-message" asp-validation-for="LastName"></span>
        </div>
    </div>
    <div class="d-flex">
        <div class="form-group col-md-5">
            <label asp-for="cpf">CPF</label>
            <input asp-for="cpf" class="form-control" />
            <span class="validation-message" asp-validation-for="cpf"></span>
        </div>
        <div class="form-group col-md-5">
            <label asp-for="Email">Email</label>
            <input asp-for="Email" class="form-control" />
            <span class="validation-message" asp-validation-for="Email"></span>
        </div>
    </div>
    <div class="d-flex">
        <div class="form-group col-md-5">
            <label asp-for="UserName">Usuário</label>
            <input asp-for="UserName" class="form-control" />
            <span class="validation-message" asp-validation-for="UserName"></span>
        </div>
        <div class="form-group col-md-5">
            <label asp-for="Password">Senha</label>
            <div class="input-group">
                <input type="password" asp-for="Password" class="form-control" id="passwordField" />
            </div>
            <span class="validation-message" asp-validation-for="Password"></span>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Criar Usuário</button>
</form>


