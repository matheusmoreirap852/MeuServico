<div class="container mt-4">

    <h2>Dashboard da Locadora</h2>

    <div class="row mt-4">

        <div class="col-md-3">

            <div class="card text-white bg-primary">

                <div class="card-body">

                    <h5>Total de Carros</h5>

                    <h2>@ViewBag.TotalCarros</h2>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card text-white bg-success">

                <div class="card-body">

                    <h5>Disponíveis</h5>

                    <h2>@ViewBag.CarrosDisponiveis</h2>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card text-white bg-danger">

                <div class="card-body">

                    <h5>Alugados</h5>

                    <h2>@ViewBag.CarrosAlugados</h2>

                </div>

            </div>

        </div>

    </div>

</div>