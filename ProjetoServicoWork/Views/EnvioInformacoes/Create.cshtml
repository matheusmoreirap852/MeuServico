@model ProjetoServicoWork.Models.RegistroServico

<link href="//cdnjs.cloudflare.com/ajax/libs/select2/4.0.0/css/select2.min.css" rel="stylesheet" />
<script src="//cdnjs.cloudflare.com/ajax/libs/select2/4.0.0/js/select2.min.js"></script>

<div class="container">
    <h4>Adicionar atleta</h4>
    <span> Equipe @ViewBag.NomeEquipe</span>
</div>

@if (!string.IsNullOrEmpty(ViewBag.Erro as string))
{
    <div class="alert alert-danger" role="alert">
        @ViewBag.Erro
    </div>
}

@if (TempData["Erro"] is string erro && !string.IsNullOrEmpty(erro))
{
    <div class="alert alert-danger" role="alert">
        @erro
    </div>
}

<form asp-action="CreateDados" id="myForm" method="post">
    <div class="container">
        <div class="form-group col-md-5 col-lg-5">
            <label asp-for="LinhaTempo" class="control-label">Linha do tempo</label>
            <select asp-for="LinhaTempo" asp-items="ViewBag.LinhasTempo" class="form-control" required>
                <option value="" disabled>Selecione</option>
            </select>


        </div>

        <div class="row">
            <div class="form-group col-md-6 col-lg-6">
                <label asp-for="Titulo" class="control-label">Título</label>
                <input asp-for="Titulo" type="text" class="form-control" required />
                <span asp-validation-for="Titulo" class="text-danger"></span>
            </div>

            <div class="form-group col-md-6 col-lg-6">
                <label asp-for="Descricao" class="control-label">Descrição</label>
                <input asp-for="Descricao" class="form-control" required />
                <span asp-validation-for="Descricao" class="text-danger"></span>
            </div>
        </div>

        <div class="row">
            <div class="form-group col-md-6 col-lg-6">
                <label asp-for="Anotacoes" class="control-label">Anotações</label>
                <input asp-for="Anotacoes" class="form-control" required />
                <span asp-validation-for="Anotacoes" class="text-danger"></span>
            </div>
        </div>

        @{
            var name = User.Claims.FirstOrDefault(t => t.Type == "name")?.Value ?? " - ";
        }

        <input type="hidden" name="modEvtUsu" value="@name" />
        <input type="hidden" name="idEvt" value="@ViewBag.idEvento" />

        <div class="container" style="background-color:#f1f1f1">
            <button style="background-color:blue" type="submit" class="btn btn-primary">Cadastro</button>
            <button type="button" class="btn btn-secondary" onclick="voltarPagina()">Voltar</button>
        </div>
    </div>
</form>
