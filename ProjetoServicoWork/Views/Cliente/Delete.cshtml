@model MeuServico.Application.Dtos.ClienteDto

<div class="container mt-4">

    <div class="card shadow border-danger">

        <!-- HEADER -->
        <div class="card-header bg-danger text-white d-flex justify-content-between">
            <h4 class="mb-0">
                <i class="fa fa-trash"></i> Confirmar Exclusão
            </h4>

            <a asp-action="Index" class="btn btn-light">
                <i class="fa fa-arrow-left"></i> Voltar
            </a>
        </div>

        <div class="card-body">

            <!-- ALERTA -->
            <div class="alert alert-danger">
                <i class="fa fa-exclamation-triangle"></i>
                Tem certeza que deseja excluir este cliente?
            </div>

            <!-- DADOS -->
            <div class="row">

                <div class="col-md-6 mb-3">
                    <label class="fw-bold">Nome</label>
                    <div class="form-control bg-light">
                        @Model.Nome
                    </div>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="fw-bold">CPF</label>
                    <div class="form-control bg-light">
                        <span class="badge bg-secondary">
                            @Model.CPF
                        </span>
                    </div>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="fw-bold">Telefone</label>
                    <div class="form-control bg-light">
                        @Model.Telefone
                    </div>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="fw-bold">CNH</label>
                    <div class="form-control bg-light">
                        @Model.CNH
                    </div>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="fw-bold">Validade CNH</label>
                    <div class="form-control bg-light">

                        @if (Model.ValidadeCNH < DateTime.Now)
                        {
                            <span class="badge bg-danger">
                                Vencida (@Model.ValidadeCNH.ToString("dd/MM/yyyy"))
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-success">
                                Válida (@Model.ValidadeCNH.ToString("dd/MM/yyyy"))
                            </span>
                        }

                    </div>
                </div>

            </div>

            <!-- FORM DELETE -->
            <form asp-action="Delete" method="post">

                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Id" />

                <div class="mt-4 d-flex gap-2">

                    <button type="submit" class="btn btn-danger">
                        <i class="fa fa-trash"></i> Confirmar Exclusão
                    </button>

                    <a asp-action="Index" class="btn btn-secondary">
                        Cancelar
                    </a>

                </div>
            </form>
        </div>
    </div>
</div>