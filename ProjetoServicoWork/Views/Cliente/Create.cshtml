@model MeuServico.Application.Dtos.ClienteDto

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">
            <h4><i class="fa fa-user-plus"></i> Novo Cliente</h4>
        </div>

        <div class="card-body">

            <form asp-action="Create">

                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Nome</label>
                        <input asp-for="Nome" class="form-control" />
                        <span asp-validation-for="Nome" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">CPF</label>
                        <input asp-for="CPF" class="form-control" />
                        <span asp-validation-for="CPF" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Telefone</label>
                        <input asp-for="Telefone" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">CNH</label>
                        <input asp-for="CNH" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Validade CNH</label>
                        <input asp-for="ValidadeCNH" type="date" class="form-control" />
                    </div>

                </div>

                <div class="mt-3">

                    <button type="submit" class="btn btn-success">
                        <i class="fa fa-save"></i> Salvar
                    </button>

                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fa fa-arrow-left"></i> Voltar
                    </a>

                </div>

            </form>

        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}