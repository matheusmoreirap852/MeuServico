@model MeuServico.Application.Dtos.ClienteDto

<div class="container mt-4">

    <div class="card shadow">

        <!-- HEADER -->
        <div class="card-header bg-warning text-dark d-flex justify-content-between">
            <h4 class="mb-0">
                <i class="fa fa-edit"></i> Editar Cliente
            </h4>

            <span class="badge bg-dark">
                ID: @Model.Id
            </span>
        </div>

        <div class="card-body">

            <form asp-action="Edit" method="post">

                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Id" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row">

                    <!-- NOME -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Nome</label>
                        <input asp-for="Nome" class="form-control" placeholder="Digite o nome" />
                        <span asp-validation-for="Nome" class="text-danger"></span>
                    </div>

                    <!-- CPF -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">CPF</label>
                        <input asp-for="CPF" class="form-control" id="CPF" placeholder="000.000.000-00" />
                        <span asp-validation-for="CPF" class="text-danger"></span>
                    </div>

                    <!-- TELEFONE -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Telefone</label>
                        <input asp-for="Telefone" class="form-control" id="Telefone" placeholder="(00) 00000-0000" />
                    </div>

                    <!-- CNH -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">CNH</label>
                        <input asp-for="CNH" class="form-control" />
                    </div>

                    <!-- VALIDADE CNH -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Validade CNH</label>
                        <input asp-for="ValidadeCNH" type="date" class="form-control" />

                        @if (Model.ValidadeCNH < DateTime.Now)
                        {
                            <small class="text-danger">
                                ⚠ CNH vencida
                            </small>
                        }
                    </div>

                </div>

                <!-- AÇÕES -->
                <div class="mt-4 d-flex gap-2">

                    <button type="submit" class="btn btn-success">
                        <i class="fa fa-save"></i> Salvar
                    </button>

                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fa fa-arrow-left"></i> Voltar
                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <!-- 🔥 jQuery (garante que existe) -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- 🔥 Mask -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>

    <script>
        $(document).ready(function () {

        $('#CPF').mask('000.000.000-00');
        $('#Telefone').mask('(00) 00000-0000');

        });
    </script>

}