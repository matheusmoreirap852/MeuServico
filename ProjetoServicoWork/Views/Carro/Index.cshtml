@model X.PagedList.IPagedList<MeuServico.Application.Dtos.CarroDto>
@using MeuServico.Core.Enums

<div class="container-fluid mt-4">

    <div class="card shadow">

        <div class="card-header bg-primary text-white d-flex justify-content-between">

            <h4 class="mb-0">
                <i class="fa fa-car"></i> Gestão de Carros
            </h4>

            <a asp-action="Create" class="btn btn-light">
                <i class="fa fa-plus"></i> Novo Carro
            </a>

        </div>

        <div class="card-body">

            <table id="carrosTable" class="table table-striped table-hover">

                <thead class="table-dark">

                    <tr>
                        <th>Placa</th>
                        <th>Marca</th>
                        <th>Modelo</th>
                        <th>Ano</th>
                        <th>KM</th>
                        <th>Status</th>
                        <th>Valor Pago</th>
                        <th>Valor Venal</th>
                        <th>Compra</th>
                        <th width="150">Ações</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var carro in Model)
                    {
                        <tr>

                            <td>@carro.Placa</td>

                            <td>@carro.Marca</td>

                            <td>@carro.Modelo</td>

                            <td>@carro.Ano</td>

                            <td>@carro.KmAtual</td>

                            <td>

                                @if (carro.Status == StatusCarro.Disponivel)
                                {
                                    <span class="badge bg-success">Disponível</span>
                                }
                                else if (carro.Status == StatusCarro.Alugado)
                                {
                                    <span class="badge bg-danger">Alugado</span>
                                }
                                else if (carro.Status == StatusCarro.EmManutencao)
                                {
                                    <span class="badge bg-warning">Manutenção</span>
                                }
                                else if (carro.Status == StatusCarro.Reservado)
                                {
                                    <span class="badge bg-info">Reservado</span>
                                }
                                else if (carro.Status == StatusCarro.Inativo)
                                {
                                    <span class="badge bg-secondary">Inativo</span>
                                }
                                else if (carro.Status == StatusCarro.Vendido)
                                {
                                    <span class="badge bg-dark">Vendido</span>
                                }

                            </td>

                            <td>@carro.ValorPago.ToString("C")</td>

                            <td>@carro.ValorVenal.ToString("C")</td>

                            <td>
                                @(carro.DataCompra?.ToString("dd/MM/yyyy") ?? "-")
                            </td>

                            <td>

                                <a asp-action="Details" asp-route-id="@carro.Id"
                                   class="btn btn-info btn-sm">
                                    <i class="fa fa-eye"></i>
                                </a>

                                <a asp-action="Edit" asp-route-id="@carro.Id"
                                   class="btn btn-warning btn-sm">
                                    <i class="fa fa-edit"></i>
                                </a>

                                <a asp-action="Delete" asp-route-id="@carro.Id"
                                   class="btn btn-danger btn-sm">
                                    <i class="fa fa-trash"></i>
                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>
    </div>
</div>

@section Scripts {

    <script>

        $(document).ready(function () {

        $('#carrosTable').DataTable({

        language: {
        url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/pt-BR.json'
        },

        pageLength: 10,
        order: [[0, 'asc']]

        });

        });

    </script>

}